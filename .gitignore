# Generated by install.sh with user-specific backup paths
uninstall.sh
restore-config.sh

# macOS metadata
.DS_Store

# Playwright MCP artifacts (screenshots, page captures, console logs)
.playwright-mcp/

# SweetClaude dogfood artifacts (internal work, not framework source)
.sweetclaude/*
/strategy/
/corpus/

# docs/ — whitelist specific subdirectories
/docs/*
!/docs/README.md
!/docs/user-guide/
!/docs/user-guide/**
!/docs/internal/
!/docs/internal/**

# docs/product/ contains real project backlog and roadmap data — never public
/docs/product/

# Internal strategy, plans, and design docs — never public
/docs-internal/

# Scratch, session artifacts, and personal setup docs
/scratch/
/audit/
/playbooks/

# Claude Code agent worktrees and local settings (machine-specific)
/.claude/

# Dev-only maintainer scripts (not part of the plugin distribution)
install.sh
scripts/bump-version.sh

# Generated script output
scripts/migration-report.md

# Python cache
__pycache__/
*.pyc
